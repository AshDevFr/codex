# Dockerfile for Codex release builds using pre-built binaries from cargo-dist
# Supports multi-arch builds (amd64, arm64) without QEMU emulation
#
# Build context expects binaries at:
#   binaries/amd64/codex  (for linux/amd64)
#   binaries/arm64/codex  (for linux/arm64)

FROM alpine:latest

# Install runtime dependencies
RUN apk add --no-cache \
    ca-certificates \
    openssl

# Create app user
RUN adduser -D -u 1000 codex

WORKDIR /app

# Copy the pre-built binary based on target architecture
# TARGETARCH is automatically set by Docker buildx (amd64 or arm64)
ARG TARGETARCH
COPY binaries/${TARGETARCH}/codex /usr/local/bin/codex
RUN chmod +x /usr/local/bin/codex

# Create directories
RUN mkdir -p /app/data /app/config && \
    chown -R codex:codex /app

USER codex

EXPOSE 8080

CMD ["codex", "serve"]
